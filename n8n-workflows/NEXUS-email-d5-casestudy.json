{
  "name": "NEXUS - Email D+5 Case Study",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 10 * * *"
            }
          ]
        }
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000001",
      "name": "Todo dia 10h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://nexusaas.com.br/api/waitlist/send-sequence",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer nexus_cron_2025"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"step\": 3, \"days_ago\": 5}"
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000002",
      "name": "Disparar Email Case Study",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-2",
              "leftValue": "={{ $json.failed }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000003",
      "name": "Houve falhas?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "message": "=NEXUS Email D+5: {{ $json.sent }} enviados, {{ $json.failed }} falhas.\n\nDetalhes: {{ JSON.stringify($json.results) }}"
      },
      "id": "b2c3d4e5-0002-0002-0002-000000000004",
      "name": "Log de Erro",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [900, 200],
      "notes": "Substitua por Slack/email de alerta se quiser notificação de erros"
    }
  ],
  "connections": {
    "Todo dia 10h": {
      "main": [
        [
          {
            "node": "Disparar Email Case Study",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Disparar Email Case Study": {
      "main": [
        [
          {
            "node": "Houve falhas?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Houve falhas?": {
      "main": [
        [
          {
            "node": "Log de Erro",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": ["NEXUS", "waitlist", "email"]
}
